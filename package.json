{
  "name": "jur-sital-site",
  "version": "1.0.0",
  "private": true,
  "description": "Jur Sital static website linting and CI setup",
  "scripts": {
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js",
    "lint:html": "htmlhint \"**/*.html\" --ignore node_modules",
    "lint:css": "stylelint \"**/*.css\" --allow-empty-input",
    "lint:js": "eslint \"**/*.js\""
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "htmlhint": "^1.7.1",
    "stylelint": "^16.16.0",
    "stylelint-config-standard": "^37.0.0"
  }
}
